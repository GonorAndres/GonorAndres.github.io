---
import { t } from '../../i18n';
import type { Lang } from '../../i18n';
import OrganicBlob from '../decorations/OrganicBlob.astro';
import LatestPostCard from '../ui/LatestPostCard.astro';
import DiscoverPostCard from '../ui/DiscoverPostCard.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="relative overflow-hidden py-10 md:py-12 px-6">
  <!-- Decorative blobs -->
  <OrganicBlob variant={1} color="#D4A574" class="w-[500px] h-[500px] -top-20 -right-40 opacity-60" />
  <OrganicBlob variant={3} color="#7A8B6F" class="w-[350px] h-[350px] bottom-0 -left-24 opacity-40" />

  <div class="max-w-6xl mx-auto relative z-10">
    <!-- Decorative circles (absolute, top-right) -->
    <div class="hidden md:block absolute top-2 right-0 lg:right-8">
      <div class="relative">
        <div class="w-28 h-28 lg:w-36 lg:h-36 rounded-full bg-gradient-to-br from-amber/30 to-terracotta/20"></div>
        <div class="absolute top-3 left-3 w-20 h-20 lg:w-28 lg:h-28 rounded-full border-2 border-sage/30"></div>
      </div>
    </div>

    <!-- Hero text -->
    <div class="md:max-w-2xl lg:max-w-3xl mb-8 md:mb-10">
      <p class="text-sage font-medium text-lg mb-2 fade-up">
        {t(lang, 'hero.greeting')}
      </p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-navy leading-tight mb-4 fade-up">
        <span class="block">Andrés</span>
        <span class="block">González Ortega</span>
      </h1>
      <p class="text-xl md:text-2xl text-terracotta font-serif mb-6 fade-up">
        {t(lang, 'hero.role')}
      </p>
      <p class="text-navy/70 text-lg max-w-lg mb-8 fade-up">
        {t(lang, 'hero.description')}
      </p>
      <div class="flex flex-wrap gap-4 fade-up">
        <a
          href="#proyectos"
          class="inline-block px-6 py-3 bg-terracotta text-cream font-medium rounded-lg hover:bg-terracotta/90 transition-colors"
        >
          {t(lang, 'hero.cta')}
        </a>
        <a
          href="https://drive.google.com/file/d/16cdRmnzf0drNv9c5848N6ZedgYX9WhwV/view"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-6 py-3 border-2 border-navy/20 text-navy font-medium rounded-lg hover:border-terracotta hover:text-terracotta transition-colors"
        >
          {t(lang, 'hero.cv')}
        </a>
      </div>
    </div>

    <!-- Blog cards side by side -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
      <div class="rounded-xl border border-navy/10 bg-white/70 shadow-md backdrop-blur-sm px-4 py-4 flex flex-col gap-3">
        <LatestPostCard lang={lang} />
      </div>
      <div class="rounded-xl border border-amber/30 bg-white/60 shadow-sm backdrop-blur-sm px-4 py-4 flex flex-col gap-3">
        <DiscoverPostCard lang={lang} />
      </div>
    </div>
  </div>
</section>
