---
import type { Lang } from '../../i18n';
import { t } from '../../i18n';
import type { ProjectCategory } from '../../data/projects';
import { getRelatedProjectNames } from '../../data/projects';
import CategoryBadge from './CategoryBadge.astro';

interface Props {
  title: string;
  description: string;
  url: string;
  repo?: string;
  platform: string;
  category: ProjectCategory;
  tags?: string[];
  variant?: 'standard' | 'tall' | 'wide';
  screenshot?: string;
  lang: Lang;
  relatedTo?: string[];
}

const { title, description, url, repo, platform, category, tags = [], variant = 'standard', screenshot, lang, relatedTo } = Astro.props;

// Variant classes are now handled by the parent grid wrapper

const categoryColors: Record<ProjectCategory, string> = {
  'actuarial': 'bg-terracotta/10 border-terracotta/20',
  'data-science': 'bg-sage/10 border-sage/20',
  'quant-finance': 'bg-amber/10 border-amber/20',
  'applied-math': 'bg-navy/10 border-navy/20',
};

const categoryBadgeColors: Record<ProjectCategory, string> = {
  'actuarial': 'bg-terracotta/20 text-terracotta',
  'data-science': 'bg-sage/20 text-sage',
  'quant-finance': 'bg-amber/20 text-amber',
  'applied-math': 'bg-navy/20 text-navy',
};

const placeholderGradients: Record<ProjectCategory, string> = {
  'actuarial': 'from-terracotta/20 via-terracotta/10 to-amber/5',
  'data-science': 'from-sage/20 via-sage/10 to-navy/5',
  'quant-finance': 'from-amber/20 via-amber/10 to-terracotta/5',
  'applied-math': 'from-navy/20 via-navy/10 to-sage/5',
};

const categoryIcons: Record<ProjectCategory, string> = {
  'actuarial': 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  'data-science': 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  'quant-finance': 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6',
  'applied-math': 'M4.871 4A17.926 17.926 0 003 12c0 2.874.673 5.59 1.871 8m14.13 0A17.926 17.926 0 0021 12a17.926 17.926 0 00-1.871-8M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
};

const categoryKey = `projects.${category}` as keyof typeof import('../../i18n/es').default;

const relatedNames = relatedTo ? getRelatedProjectNames(relatedTo, lang) : [];

const isWide = variant === 'wide';

const platformLabels: Record<string, Record<Lang, string>> = {
  'GCP':    { es: 'Abrir app',        en: 'Open app' },
  'Vercel': { es: 'Abrir app',        en: 'Open app' },
  'GitHub': { es: 'Ver repositorio',  en: 'View repository' },
  'Drive':  { es: 'Abrir en Drive',   en: 'Open in Drive' },
  'Colab':  { es: 'Abrir notebook',   en: 'Open in Colab' },
};
const linkLabel = platformLabels[platform]?.[lang] ?? t(lang, 'projects.viewProject');
---

<article
  class:list={[
    'group relative flex flex-col h-full rounded-2xl border overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1.5 fade-up',
    categoryColors[category],
  ]}
>
  <!-- Visual area -->
  <a
    href={url}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'block relative overflow-hidden',
      isWide ? 'h-48 md:h-56' : 'h-40 md:h-44',
    ]}
  >
    {screenshot ? (
      <img
        src={screenshot}
        alt={title}
        class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    ) : (
      <div class:list={[
        'w-full h-full bg-gradient-to-br flex items-center justify-center relative',
        placeholderGradients[category],
      ]}>
        <!-- Decorative grid pattern -->
        <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 20px 20px;"></div>
        <!-- Category icon -->
        <svg class="w-12 h-12 text-navy/20 transition-transform duration-500 group-hover:scale-110 group-hover:text-navy/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={categoryIcons[category]} />
        </svg>
      </div>
    )}

    <!-- Category badge overlaid on image -->
    <div class="absolute top-3 left-3 flex items-center gap-2">
      <span class:list={[
        'text-xs font-medium px-2.5 py-1 rounded-full backdrop-blur-sm',
        screenshot ? 'bg-white/80 text-navy/80' : categoryBadgeColors[category],
      ]}>
        {t(lang, categoryKey)}
      </span>
      <span class:list={[
        'text-xs px-2 py-1 rounded-full',
        screenshot ? 'bg-white/60 text-navy/60 backdrop-blur-sm' : 'bg-white/40 text-navy/50',
      ]}>
        {platform}
      </span>
    </div>
  </a>

  <!-- Content area -->
  <div class="flex flex-col flex-1 p-5">
    <h3 class="font-serif text-lg font-bold text-navy mb-2 group-hover:text-terracotta transition-colors leading-snug">
      {title}
    </h3>

    <p class:list={[
      'text-sm text-navy/60 flex-1 mb-3 leading-relaxed',
      isWide ? 'line-clamp-3' : 'line-clamp-4',
    ]}>
      {description}
    </p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-3">
        {tags.slice(0, isWide ? 6 : 4).map((tag) => (
          <CategoryBadge label={tag} />
        ))}
        {tags.length > (isWide ? 6 : 4) && (
          <span class="text-xs text-navy/30 self-center">+{tags.length - (isWide ? 6 : 4)}</span>
        )}
      </div>
    )}

    {relatedNames.length > 0 && (
      <p class="text-xs text-navy/35 mb-3 italic leading-relaxed">
        {t(lang, 'projects.seeAlso')} {relatedNames.join(', ')}
      </p>
    )}

    <div class="flex items-center gap-4 mt-auto flex-wrap">
      {repo && (
        <a
          href={repo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm font-medium text-navy/50 hover:text-navy/80 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
          </svg>
          {lang === 'es' ? 'Ver repositorio' : 'View repository'}
        </a>
      )}
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-terracotta hover:text-terracotta/80 transition-colors"
      >
        {repo ? (lang === 'es' ? 'Usar página en vivo' : 'Open live site') : linkLabel}
        <svg class="w-4 h-4 group-hover:translate-x-1.5 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</article>
