---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import NotesSearch from '../../../components/ui/NotesSearch';
import { t } from '../../../i18n';
import { getNotes, noteCategories, noteCategoryLabels } from '../../../data/notes';
import OrganicBlob from '../../../components/decorations/OrganicBlob.astro';

const allNotes = getNotes('en');

const notesData = allNotes.map((note) => ({
  slug: note.slug,
  category: noteCategoryLabels['en'][note.category],
  title: note.title,
  description: note.description,
  urls: note.urls,
  tags: note.tags,
  lang: 'en' as const,
}));

const categoryOptions = noteCategories.map((cat) => ({
  value: noteCategoryLabels['en'][cat],
  label: noteCategoryLabels['en'][cat],
}));

const labels = {
  searchPlaceholder: t('en', 'notes.searchPlaceholder'),
  noResults: t('en', 'notes.noResults'),
  noteSingular: t('en', 'notes.noteSingular'),
  notePlural: t('en', 'notes.notePlural'),
  allCategories: t('en', 'notes.allCategories'),
  viewPdf: t('en', 'notes.viewPdf'),
  details: t('en', 'notes.details'),
};
---

<BaseLayout title="Notes & Study Materials | Actuarial, Finance, Statistics" description={t('en', 'notes.subtitle')} lang="en">
  <section class="relative py-16 px-6">
    <OrganicBlob variant={1} color="#D4A574" class="w-[400px] h-[400px] -top-16 -right-20 opacity-20" />

    <div class="max-w-4xl mx-auto relative z-10">
      <h1 class="text-3xl md:text-5xl font-bold text-navy mb-2 fade-up">{t('en', 'notes.title')}</h1>
      <p class="text-navy/60 mb-8 fade-up">{t('en', 'notes.subtitle')}</p>

      <div class="flex flex-wrap gap-2 mb-10 fade-up">
        <a href="/en/notes/" class="text-sm px-3 py-1 rounded-full bg-terracotta text-cream">
          {t('en', 'notes.allNotes')}
        </a>
        {noteCategories.map((cat) => (
          <a href={`/en/notes/categoria/${cat}/`} class="text-sm px-3 py-1 rounded-full bg-sage/15 text-sage hover:bg-sage/25 transition-colors">
            {noteCategoryLabels['en'][cat]}
          </a>
        ))}
      </div>

      <NotesSearch client:idle notes={notesData} labels={labels} categoryOptions={categoryOptions} />
    </div>
  </section>
</BaseLayout>
