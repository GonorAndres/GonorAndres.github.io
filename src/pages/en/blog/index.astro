---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogSearch from '../../../components/ui/BlogSearch';
import { t } from '../../../i18n';
import { categories, categoryLabels, type Category } from '../../../data/categories';
import OrganicBlob from '../../../components/decorations/OrganicBlob.astro';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === 'en')
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const postsData = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  slug: post.id.replace(/^(es|en)\//, ''),
  date: post.data.date,
  category: post.data.category,
  categoryLabel: categoryLabels['en'][post.data.category as Category] ?? post.data.category,
  lang: 'en' as const,
}));

const labels = {
  searchPlaceholder: t('en', 'blog.searchPlaceholder'),
  allYears: t('en', 'blog.allYears'),
  noResults: t('en', 'blog.noResults'),
  readMore: t('en', 'blog.readMore'),
  articleSingular: t('en', 'blog.articleSingular'),
  articlePlural: t('en', 'blog.articlePlural'),
};
---

<BaseLayout title="Blog | Andres Gonzalez Ortega" lang="en">
  <section class="relative py-16 px-6 overflow-hidden">
    <OrganicBlob variant={1} color="#D4A574" class="w-[400px] h-[400px] -top-16 -right-20 opacity-20" />

    <div class="max-w-4xl mx-auto relative z-10">
      <h1 class="text-3xl md:text-5xl font-bold text-navy mb-4 fade-up">{t('en', 'section.blog')}</h1>

      <div class="flex flex-wrap gap-2 mb-10 fade-up">
        <a href="/en/blog/" class="text-sm px-3 py-1 rounded-full bg-terracotta text-cream">
          {t('en', 'blog.allPosts')}
        </a>
        {categories.map((cat) => (
          <a href={`/en/blog/categoria/${cat}/`} class="text-sm px-3 py-1 rounded-full bg-sage/15 text-sage hover:bg-sage/25 transition-colors">
            {categoryLabels['en'][cat]}
          </a>
        ))}
      </div>

      <BlogSearch client:idle posts={postsData} labels={labels} />
    </div>
  </section>
</BaseLayout>
